---
# Copy to credentials.yml, replace every value, set mode 0600, and encrypt
# with Ansible Vault before using this project outside a test environment.
sftp_password: replace-with-strong-sftp-password
db_password: replace-with-strong-database-password
wp_admin_password: replace-with-strong-wordpress-password
phpmyadmin_blowfish_secret: replace-with-at-least-32-random-characters
