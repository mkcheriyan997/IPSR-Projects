pipeline {
    agent any

    environment {
        APP_NAME = 'blue-green-app'
        VERSION = "2.0.${env.BUILD_ID}"
        PROJECT_DIR = 'jenkins-blue-green-project'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Determine Target Environment') {
            steps {
                dir("${PROJECT_DIR}") {
                    script {
                        // Check Nginx config to see which environment is currently active
                        // Looking for 'set $active_app app_blue;'
                        def isBlue = sh(script: "grep -q 'set \\\$active_app app_blue;' nginx/nginx.conf", returnStatus: true) == 0
                        
                        if (isBlue) {
                            env.TARGET_ENV = 'green'
                            env.TARGET_PORT = '8002'
                            env.CURRENT_ENV = 'blue'
                        } else {
                            env.TARGET_ENV = 'blue'
                            env.TARGET_PORT = '8001'
                            env.CURRENT_ENV = 'green'
                        }
                        echo "Current active environment: ${env.CURRENT_ENV}"
                        echo "Deploying to target environment: ${env.TARGET_ENV} on port ${env.TARGET_PORT}"
                    }
                }
            }
        }

        stage('Deploy to Target Environment') {
            steps {
                dir("${PROJECT_DIR}") {
                    script {
                        echo "Deploying Version ${VERSION} to ${env.TARGET_ENV}..."
                        // Disable BuildKit to avoid Buildx 0.17+ requirement on this EC2
                        sh "DOCKER_BUILDKIT=0 VERSION=${VERSION} docker-compose up -d --build app_${env.TARGET_ENV}"
                    }
                }
            }
        }

        stage('Smoke Test') {
            steps {
                dir("${PROJECT_DIR}") {
                    script {
                        echo "Running smoke tests on ${env.TARGET_ENV} (localhost:${env.TARGET_PORT})..."
                        // Wait a few seconds for the app to start
                        sleep 5
                        def response = sh(script: "curl -s http://localhost:${env.TARGET_PORT}/health", returnStdout: true).trim()
                        if (response != "OK") {
                            error "Smoke test failed! Application on ${env.TARGET_ENV} is not healthy."
                        }
                        echo "Smoke test passed!"
                    }
                }
            }
        }

        stage('Switch Traffic') {
            steps {
                dir("${PROJECT_DIR}") {
                    script {
                        echo "Switching traffic to ${env.TARGET_ENV}..."
                        
                        // Update the variable in Nginx config
                        sh "sed -i 's/set \\\$active_app app_[a-z]\\+;/set \\\$active_app app_${env.TARGET_ENV};/' nginx/nginx.conf"
                        
                        // Force a small delay to ensure file propagation
                        sleep 2
                        
                        echo "Reloading Nginx config..."
                        // Zero-downtime reload Nginx
                        sh "docker exec nginx_lb nginx -s reload"
                        
                        echo "Traffic switched successfully to ${VERSION} on ${env.TARGET_ENV}."
                    }
                }
            }
        }
    }

    post {
        failure {
            dir("${PROJECT_DIR}") {
                script {
                    echo "Pipeline failed! Rolling back/Cleaning up..."
                    echo "Stopping the failed ${env.TARGET_ENV} deployment..."
                    sh "docker-compose stop app_${env.TARGET_ENV} || true"
                    sh "docker-compose rm -f app_${env.TARGET_ENV} || true"
                    
                    emailext (
                        subject: "DEPLOYMENT FAILED: ${env.JOB_NAME} [${env.BUILD_NUMBER}]",
                        body: "Blue-Green deployment failed during '${env.STAGE_NAME}'. Rolled back to ${env.CURRENT_ENV}.",
                        to: 'mkcheriyan997@gmail.com'
                    )
                }
            }
        }
        success {
            echo "Deployment Successful!"
            emailext (
                subject: "DEPLOYMENT SUCCESS: ${env.JOB_NAME} [${env.BUILD_NUMBER}]",
                body: "Blue-Green deployment successful. Version ${VERSION} is now live on ${env.TARGET_ENV}.",
                to: 'mkcheriyan997@gmail.com'
            )
        }
    }
}
